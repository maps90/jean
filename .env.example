JEAN_SLACK_BOT_TOKEN=xoxb-...
JEAN_SLACK_APP_TOKEN=xapp-...
# Auth: set EXACTLY ONE of the two below.
#  - ANTHROPIC_API_KEY: pay-as-you-go API billing (wins if both are set).
#  - CLAUDE_CODE_OAUTH_TOKEN: use a Claude Pro/Max subscription. Generate on a
#    machine logged into Claude Code with `claude setup-token`, paste here. The
#    SDK child + soul extractor auto-detect it and authenticate via OAuth Bearer
#    against api.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
JEAN_HOME=~/.jean
JEAN_DATABASE_URL=postgresql://jean:jean@localhost:5432/jean
# Per-worker asyncpg pool bounds. Each worker also opens one LISTEN connection
# on top of the pool, so N workers cost N*(MAX+1) slots against the server's
# `max_connections`. Shrink these when sharing a small managed Postgres.
JEAN_DB_POOL_MIN=1
JEAN_DB_POOL_MAX=5
JEAN_IDLE_MINUTES=15
JEAN_APPROVAL_TTL=1800
JEAN_PERMISSION_MODE=bypassPermissions
JEAN_HEALTH_PORT=8080
JEAN_MODEL=claude-opus-4-8
JEAN_SOUL_PARSE_MODEL=claude-haiku-4-5-20251001
# Postgres retention cleanup, swept every JEAN_CLEANUP_INTERVAL_HOURS by whichever
# worker claims the cycle. Sessions and approvals expire on separate schedules:
#  - sessions idle longer than JEAN_SESSION_RETENTION_DAYS are deleted, and their
#    transcript goes with them (FK cascade) -- along with `engaged` and
#    `permission_mode`, so a thread quiet this long needs a fresh @-mention.
#  - resolved approvals older than JEAN_APPROVAL_RETENTION_DAYS are deleted
#    (the audit trail outlives the memory).
# Set JEAN_CLEANUP_ENABLED=false to disable the sweep entirely.
JEAN_CLEANUP_ENABLED=true
JEAN_SESSION_RETENTION_DAYS=3
JEAN_APPROVAL_RETENTION_DAYS=30
JEAN_CLEANUP_INTERVAL_HOURS=24
# Refuse to archive a transcript bigger than this rather than let one pathological
# thread bloat the database. Such a thread keeps working, but only on the worker
# holding it -- it will not resume elsewhere.
JEAN_TRANSCRIPT_MAX_MB=32
